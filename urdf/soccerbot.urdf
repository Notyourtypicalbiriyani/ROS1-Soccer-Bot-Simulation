<?xml version="1.0"?>
<robot name="soccerbot">

  <!-- Base footprint -->
  <link name="base_footprint"/>

  <joint name="footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- VERTICAL RECTANGLE BODY -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.20"/>
      <geometry>
        <!-- Width = 0.20, Depth = 0.15, Height = 0.40 -->
        <box size="0.20 0.15 0.40"/>
      </geometry>
      <material name="Gazebo/Blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.20"/>
      <geometry>
        <box size="0.20 0.15 0.40"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.06" ixy="0" ixz="0"
               iyy="0.06" iyz="0"
               izz="0.04"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>
      <material name="Gazebo/Black"/>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0" ixz="0"
               iyy="0.002" iyz="0"
               izz="0.002"/>
    </inertial>
  </link>

  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <mu1>20</mu1>
    <mu2>10</mu2>

  </gazebo>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.05 0.12 0.03"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>
      <material name="Gazebo/Black"/>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0" ixz="0"
               iyy="0.002" iyz="0"
               izz="0.002"/>
    </inertial>
  </link>

  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <mu1>20</mu1>
    <mu2>10</mu2>

  </gazebo>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.05 -0.12 0.03"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- CASTER WHEEL AT BACK -->
  <link name="caster_wheel">
    <visual>
      <origin xyz="-0.05 0 0.015"/>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="Gazebo/Grey"/>
    </visual>

    <collision>
      <origin xyz="-0.05 0 0.015"/>
      <geometry><sphere radius="0.025"/></geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.00005" iyz="0"
               izz="0.00005"/>
    </inertial>
  </link>

  <gazebo reference="caster_wheel">
    <material>Gazebo/Grey</material>
    <mu1>10</mu1>
    <mu2>5</mu2>
  </gazebo>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.05 0 0.015"/>
  </joint>

<!-- CAMERA -->
<link name="camera_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry><box size="0.04 0.04 0.04"/></geometry>
    <material name="Gazebo/Red"/>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry><box size="0.04 0.04 0.04"/></geometry>
  </collision>

  <inertial>
    <mass value="0.2"/>
    <inertia ixx="0.0001" ixy="0" ixz="0"
             iyy="0.0001" iyz="0"
             izz="0.0001"/>
  </inertial>
</link>

<joint name="camera_joint" type="fixed">
  <parent link="base_link"/>
  <child link="camera_link"/>
  <origin xyz="0.12 0 0.55" rpy="0 0.65 0"/>

</joint>

<gazebo reference="camera_link">
  <material>Gazebo/Red</material>

  <sensor name="camera_sensor" type="camera">
    <always_on>true</always_on>
    <update_rate>30</update_rate>

    <camera>
      <horizontal_fov>1.0</horizontal_fov>
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.05</near>
        <far>10.0</far>
      </clip>
    </camera>

    <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
      <robotNamespace>/</robotNamespace>
      <cameraName>soccerbot_cam</cameraName>
      <imageTopicName>camera/image_raw</imageTopicName>
      <cameraInfoTopicName>camera/camera_info</cameraInfoTopicName>
      <frameName>camera_link</frameName>
    </plugin>
  </sensor>
</gazebo>


 <!-- MODEL-LEVEL GAZEBO PLUGIN: DIFF DRIVE (matches left_wheel_joint / right_wheel_joint) -->
<gazebo>
  <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
    <!-- Exact joint names from your URDF -->
    <leftJoint>left_wheel_joint</leftJoint>
    <rightJoint>right_wheel_joint</rightJoint>

    <!-- topic to listen for velocity commands -->
    <commandTopic>/cmd_vel_blue</commandTopic>

    <!-- odometry topic & frames -->
    <odometryTopic>/odom</odometryTopic>
    <odometryFrame>odom</odometryFrame>
    <robotBaseFrame>base_link</robotBaseFrame>

    <!-- wheel geometry (adjust if you changed sizes) -->
    <wheelSeparation>0.24</wheelSeparation>
    <wheelDiameter>0.11</wheelDiameter>

    <!-- publish TF + joint states so robot_state_publisher and others work -->
    <publishTf>true</publishTf>
    <publishWheelTF>false</publishWheelTF>
    <publishWheelJointState>true</publishWheelJointState>

    <!-- tuning -->
    <updateRate>50</updateRate>
    <wheelTorque>50</wheelTorque>
  </plugin>
</gazebo>


</robot>

