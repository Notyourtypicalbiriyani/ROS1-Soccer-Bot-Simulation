<?xml version="1.0"?>
<robot name="soccerbot_red">

  <!-- Base footprint -->
  <link name="base_footprint_red"/>

  <joint name="footprint_to_base_red" type="fixed">
    <parent link="base_footprint_red"/>
    <child link="base_link_red"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- BODY -->
  <link name="base_link_red">
    <visual>
      <origin xyz="0 0 0.20"/>
      <geometry><box size="0.20 0.15 0.40"/></geometry>

      <material name="red_body_mat">
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Red</name>
        </script>
      </material>

    </visual>

    <collision>
      <origin xyz="0 0 0.20"/>
      <geometry><box size="0.20 0.15 0.40"/></geometry>
    </collision>

    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.06" ixy="0" ixz="0"
               iyy="0.06" iyz="0"
               izz="0.04"/>
    </inertial>
  </link>

  <!-- LEFT WHEEL -->
  <link name="left_wheel_red">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>

      <material name="wheel_mat_red">
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Black</name>
        </script>
      </material>

    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0" ixz="0"
               iyy="0.002" iyz="0"
               izz="0.002"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint_red" type="continuous">
    <parent link="base_link_red"/>
    <child link="left_wheel_red"/>
    <origin xyz="0.05 0.12 0.03"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel_red">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>

      <material name="wheel_mat_red2">
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Black</name>
        </script>
      </material>

    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.055" length="0.03"/></geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0" ixz="0"
               iyy="0.002" iyz="0"
               izz="0.002"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint_red" type="continuous">
    <parent link="base_link_red"/>
    <child link="right_wheel_red"/>
    <origin xyz="0.05 -0.12 0.03"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- CASTER -->
  <link name="caster_wheel_red">
    <visual>
      <origin xyz="-0.05 0 0.015"/>
      <geometry><sphere radius="0.025"/></geometry>

      <material name="caster_mat_red">
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Grey</name>
        </script>
      </material>

    </visual>

    <collision>
      <origin xyz="-0.05 0 0.015"/>
      <geometry><sphere radius="0.025"/></geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.00005" iyz="0"
               izz="0.00005"/>
    </inertial>
  </link>

  <joint name="caster_joint_red" type="fixed">
    <parent link="base_link_red"/>
    <child link="caster_wheel_red"/>
    <origin xyz="-0.05 0 0.015"/>
  </joint>

  <!-- CAMERA -->
  <link name="camera_link_red">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.04 0.04 0.04"/></geometry>

      <material name="camera_mat_red">
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Red</name>
        </script>
      </material>

    </visual>

    <collision><geometry><box size="0.04 0.04 0.04"/></geometry></collision>

    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint_red" type="fixed">
    <parent link="base_link_red"/>
    <child link="camera_link_red"/>
    <origin xyz="0.12 0 0.55" rpy="0 0.65 0"/>
  </joint>

  <!-- CAMERA SENSOR -->
  <gazebo reference="camera_link_red">
    <sensor name="camera_red" type="camera">
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.0</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>10.0</far></clip>
      </camera>

      <plugin name="redbot_cam_controller" filename="libgazebo_ros_camera.so">
        <robotNamespace>/soccerbot_red</robotNamespace>
        <cameraName>red_cam</cameraName>
        <imageTopicName>camera/image_raw_red</imageTopicName>
        <cameraInfoTopicName>camera/camera_info_red</cameraInfoTopicName>
        <frameName>camera_link_red</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- DIFF DRIVE -->
  <gazebo>
    <plugin name="gazebo_ros_diff_drive_red" filename="libgazebo_ros_diff_drive.so">
      <leftJoint>left_wheel_joint_red</leftJoint>
      <rightJoint>right_wheel_joint_red</rightJoint>

      <commandTopic>/cmd_vel_red</commandTopic>

      <wheelSeparation>0.24</wheelSeparation>
      <wheelDiameter>0.11</wheelDiameter>

      <robotBaseFrame>base_link_red</robotBaseFrame>

      <publishTf>true</publishTf>
      <publishWheelJointState>true</publishWheelJointState>
      <updateRate>50</updateRate>
    </plugin>
  </gazebo>



<!-- GAZEBO MATERIAL FIXES -->
<gazebo reference="base_link_red">
  <material>Gazebo/Red</material>
</gazebo>

<gazebo reference="left_wheel_red">
  <material>Gazebo/Black</material>
</gazebo>

<gazebo reference="right_wheel_red">
  <material>Gazebo/Black</material>
</gazebo>

<gazebo reference="caster_wheel_red">
  <material>Gazebo/Grey</material>
</gazebo>

<gazebo reference="camera_link_red">
  <material>Gazebo/Red</material>
</gazebo>

</robot>

